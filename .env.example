# Roots — local environment template
#
# Copy this file to `.env` in the project root and fill in your own
# credentials. The `.env` file itself is in `.gitignore` and never
# committed. The values here are placeholders.
#
# To create your own credentials:
#   1. Go to https://console.cloud.google.com/apis/credentials
#   2. Create an OAuth 2.0 Client ID, type "Web application"
#   3. Add authorized redirect URI: http://127.0.0.1:3000/auth/google/callback
#   4. Add your Gmail as a test user under OAuth consent screen
#   5. Enable the Gmail API under APIs & Services → Library
#   6. Paste your client ID and secret below

GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
